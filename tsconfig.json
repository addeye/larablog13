{
  "compilerOptions": {
    "jsx": "react-jsx", // Gunakan 'react-jsx' untuk React 17 ke atas
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./resources/js/*"]
    }
  }
}
